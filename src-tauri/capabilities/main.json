{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Permissões padrão da janela principal",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:default",
    "shell:allow-open",
    "process:allow-exit",
    "process:allow-restart"
  ]
}
